# Client (optional override): defaults to same-origin /api/stt/auth
# VITE_STT_BROKER_URL=http://localhost:8787/api/stt/auth

# Local dev convenience: Vite proxy target for /api/stt/auth
# In production on Vercel, keep using same-origin /api/stt/auth and set DEEPGRAM_API_KEY in Vercel env vars.
# VITE_BROKER_PROXY_TARGET=http://localhost:8787

# Server-only required (local broker and Vercel Function)
DEEPGRAM_API_KEY=

# Server-only optional
# STT_BROKER_PORT=8787
# STT_BROKER_TIMEOUT_MS=5000
# STT_BROKER_RATE_LIMIT_WINDOW_MS=60000
# STT_BROKER_RATE_LIMIT_MAX=30
# DEEPGRAM_TOKEN_TTL_SECONDS=60
# STT_BROKER_CORS_ALLOWLIST=https://your-web-origin.example.com

# Deprecated (removed from normal path)
# VITE_DEEPGRAM_API_KEY=
